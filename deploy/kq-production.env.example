# KQremoteLink 正式环境变量模板
# 把本文件复制到正式服务器后，按注释补齐空值。
# 推荐服务器路径：
#   /www/wwwroot/KQromoteLink/.env
#
# 注意：本仓库文件不能提交真实数据库密码、支付私钥、hbbs 私钥。
# 需要真实值时，在服务器本地 .env 中配置，不要再提交回 Git。

###############################################################################
# 部署时使用的变量
# 执行 deploy/deploy-rustdesk-server.sh 时使用。
###############################################################################

PUBLIC_HOST=remotelink.kunqiongai.com
INSTALL_DIR=/www/wwwroot/KQromoteLink
COMPOSE_PROFILES=api

KQ_ENABLE_API=Y
KQ_ENABLE_LOCAL_DB=N

# hbbs 使用的 RustDesk 中继服务地址。
KQ_RELAY_SERVER=remotelink.kunqiongai.com:21117

# RustDesk 服务端 key 选项。没有特殊要求时保持 "_"。
KQ_SERVER_KEY=_

# hbbs/hbbr 身份密钥对，仓库内留空。
# 正式环境生成一次后固定使用：
#   powershell -ExecutionPolicy Bypass -File scripts/new-kq-server-key-pair.ps1
# 公钥也就是客户端配置里的 ServerKey。
# 如果正式服务器已经在运行，并且必须沿用当前 key，
# 就从服务器导出现有 key，不要重新生成：
#   cat /www/wwwroot/KQromoteLink/data/id_ed25519.pub
#   cat /www/wwwroot/KQromoteLink/data/id_ed25519
KQ_HBBS_PUBLIC_KEY=
KQ_HBBS_SECRET_KEY=

###############################################################################
# KQ API
###############################################################################

KQ_API_PORT=21120
KQ_API_PUBLIC_PATH=/kq-api
KQ_PUBLIC_API_URL=https://remotelink.kunqiongai.com/kq-api/api

KQ_APP_SCHEME=kqremote
KQ_SUBSITE_NAME=https://remote.kunqiongai.com/
KQ_API_WEB_BASE_URL=https://api-web.kunqiongai.com

###############################################################################
# 下载资源
###############################################################################

KQ_DOWNLOAD_URL=https://remotelink.kunqiongai.com/kq-api/download/windows
KQ_DOWNLOAD_FILE_PATH=/app/public/downloads/Kunqiong-Remote-Desktop-Setup.exe
KQ_DOWNLOAD_FILE_NAME=Kunqiong-Remote-Desktop-Setup.exe
KQ_DOWNLOAD_VERSION=2026.06.26.2060
KQ_DOWNLOAD_SHA256=4C3E608C6AF09F6BEE70597DA0691253F0771C0E1E6F7CD8200F87A05826341A

KQ_ANDROID_DOWNLOAD_URL=https://remotelink.kunqiongai.com/kq-api/download/android
KQ_ANDROID_DOWNLOAD_FILE_PATH=/app/public/downloads/Kunqiong-Remote-Desktop.apk
KQ_ANDROID_DOWNLOAD_FILE_NAME=Kunqiong-Remote-Desktop.apk
KQ_ANDROID_DOWNLOAD_VERSION=1.4.6+4067
KQ_ANDROID_DOWNLOAD_SHA256=1158207394F9E5A875CDDDBB45A01BE7A3789557157888C6B3A9700095165C8B

KQ_DOWNLOAD_MAX_REQUESTS_PER_WINDOW=12
KQ_DOWNLOAD_RATE_WINDOW_MS=60000
KQ_DOWNLOAD_MAX_PER_IP_CONCURRENT=2
KQ_DOWNLOAD_MAX_GLOBAL_CONCURRENT=8

###############################################################################
# 数据库，仓库内不提交真实账号密码。
# 如果数据库和 API 部署在同一台机器，KQ_DB_HOST 通常填 127.0.0.1。
# 如果使用云数据库，KQ_DB_HOST 填云数据库内网地址或公网地址。
###############################################################################

KQ_DB_HOST=
KQ_DB_PORT=3306
KQ_DB_USER=
KQ_DB_PASSWORD=
KQ_DB_NAME=kq_remote_link
KQ_DB_POOL_SIZE=2

# 可选。只有需要部署过程初始化数据库时才配置。
KQ_DB_ROOT_PASSWORD=
KQ_DB_CREATE_DATABASE=

###############################################################################
# 支付宝。AppID 不是密钥，可以保留；私钥/公钥在正式服务器本地配置。
###############################################################################

KQ_ALIPAY_APP_ID=2021006163671041
KQ_ALIPAY_PRIVATE_KEY=
KQ_ALIPAY_PUBLIC_KEY=
KQ_ALIPAY_NOTIFY_URL=https://remotelink.kunqiongai.com/kq-api/api/payment/alipay/notify
KQ_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do

# 可选。只有把支付宝密钥保存为服务器本地文件时才配置路径。
KQ_ALIPAY_PRIVATE_KEY_PATH=
KQ_ALIPAY_PUBLIC_KEY_PATH=

###############################################################################
# 微信支付当前不是正式开放支付方式；未接入正式参数时保持为空。
###############################################################################

KQ_WECHAT_PAY_APPID=
KQ_WECHAT_PAY_MCHID=
KQ_WECHAT_PAY_MERCHANT_SERIAL_NO=
KQ_WECHAT_PAY_PRIVATE_KEY=
KQ_WECHAT_PAY_API_V3_KEY=
KQ_WECHAT_PAY_NOTIFY_URL=https://remotelink.kunqiongai.com/kq-api/api/payment/wechat/notify
KQ_WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com

# 可选。只有把微信支付私钥保存为服务器本地文件时才配置路径。
KQ_WECHAT_PAY_PRIVATE_KEY_PATH=

###############################################################################
# Android 安装包发布脚本
# 执行 scripts/deploy/deploy-android.sh 时使用。
###############################################################################

ARTIFACT_DIR=artifacts
OUTPUT_DIR=/www/wwwroot/KQromoteLink/android
API_DOWNLOAD_DIR=/www/wwwroot/KQromoteLink/api/public/downloads
KQ_API_ENV_FILE=/www/wwwroot/KQromoteLink/.env

# 可选。Android 发布脚本没有识别到版本时使用。
BUILD_NAME=
BUILD_NUMBER=

###############################################################################
# iOS Codemagic / TestFlight
# 这些值在 Codemagic 的 appstore_credentials 环境变量组里设置。
# App Store Connect 私钥等敏感值不提交到仓库。
###############################################################################

FLUTTER_BUILD_NAME=1.4.6
FLUTTER_BUILD_NUMBER=4073

BUNDLE_ID=com.kunqiong.remotelink
EXTENSION_BUNDLE_ID=com.kunqiong.remotelink.broadcast

APP_STORE_CONNECT_PRIVATE_KEY=
APP_STORE_CONNECT_KEY_IDENTIFIER=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_APPLE_ID=

# 可选。
APP_STORE_CONNECT_ASC_PUBLIC_ID=

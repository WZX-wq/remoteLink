# KQremoteLink production environment template
# Copy this file to the production server and fill the placeholder values.
# Recommended server path:
#   /www/wwwroot/KQromoteLink/.env
#
# Do not commit real secrets after filling this file.

###############################################################################
# Deployment-time variables
# Use these when running deploy/deploy-rustdesk-server.sh.
###############################################################################

PUBLIC_HOST=remotelink.kunqiongai.com
INSTALL_DIR=/www/wwwroot/KQromoteLink
COMPOSE_PROFILES=api

KQ_ENABLE_API=Y
KQ_ENABLE_LOCAL_DB=N

# RustDesk relay endpoint used by hbbs.
KQ_RELAY_SERVER=remotelink.kunqiongai.com:21117

# RustDesk server key option. Keep "_" unless you have a specific value.
KQ_SERVER_KEY=_

# hbbs/hbbr identity key pair.
# Generate once and keep fixed for production:
#   powershell -ExecutionPolicy Bypass -File scripts/new-kq-server-key-pair.ps1
# Public key is also the client ServerKey.
# If the production server is already running and must keep the current key,
# export these from the server instead of generating a new pair:
#   cat /www/wwwroot/KQromoteLink/data/id_ed25519.pub
#   cat /www/wwwroot/KQromoteLink/data/id_ed25519
KQ_HBBS_PUBLIC_KEY=<fill-generated-hbbs-public-key>
KQ_HBBS_SECRET_KEY=<fill-generated-hbbs-secret-key>

###############################################################################
# KQ API
###############################################################################

KQ_API_PORT=21120
KQ_API_PUBLIC_PATH=/kq-api
KQ_PUBLIC_API_URL=https://remotelink.kunqiongai.com/kq-api/api

KQ_APP_SCHEME=kqremote
KQ_SUBSITE_NAME=https://remote.kunqiongai.com/
KQ_API_WEB_BASE_URL=https://api-web.kunqiongai.com

###############################################################################
# Download resources
###############################################################################

KQ_DOWNLOAD_URL=https://remotelink.kunqiongai.com/kq-api/download/windows
KQ_DOWNLOAD_FILE_PATH=/app/public/downloads/Kunqiong-Remote-Desktop-Setup.exe
KQ_DOWNLOAD_FILE_NAME=Kunqiong-Remote-Desktop-Setup.exe
KQ_DOWNLOAD_VERSION=<fill-windows-version>
KQ_DOWNLOAD_SHA256=<fill-windows-installer-sha256>

KQ_ANDROID_DOWNLOAD_URL=https://remotelink.kunqiongai.com/kq-api/download/android
KQ_ANDROID_DOWNLOAD_FILE_PATH=/app/public/downloads/Kunqiong-Remote-Desktop.apk
KQ_ANDROID_DOWNLOAD_FILE_NAME=Kunqiong-Remote-Desktop.apk
KQ_ANDROID_DOWNLOAD_VERSION=<fill-android-version>
KQ_ANDROID_DOWNLOAD_SHA256=<fill-android-apk-sha256>

KQ_DOWNLOAD_MAX_REQUESTS_PER_WINDOW=12
KQ_DOWNLOAD_RATE_WINDOW_MS=60000
KQ_DOWNLOAD_MAX_PER_IP_CONCURRENT=2
KQ_DOWNLOAD_MAX_GLOBAL_CONCURRENT=8

###############################################################################
# Database
###############################################################################

KQ_DB_HOST=<fill-database-host>
KQ_DB_PORT=3306
KQ_DB_USER=<fill-database-user>
KQ_DB_PASSWORD=<fill-database-password>
KQ_DB_NAME=kq_remote_link
KQ_DB_POOL_SIZE=2

# Optional. Only fill these when the deploy process should initialize DB.
KQ_DB_ROOT_PASSWORD=
KQ_DB_CREATE_DATABASE=

###############################################################################
# Alipay
###############################################################################

KQ_ALIPAY_APP_ID=<fill-alipay-app-id>
KQ_ALIPAY_PRIVATE_KEY=<fill-alipay-app-private-key>
KQ_ALIPAY_PUBLIC_KEY=<fill-alipay-public-key>
KQ_ALIPAY_NOTIFY_URL=https://remotelink.kunqiongai.com/kq-api/api/payment/alipay/notify
KQ_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do

# Optional path-based key variables. Leave empty unless using server-local files.
KQ_ALIPAY_PRIVATE_KEY_PATH=
KQ_ALIPAY_PUBLIC_KEY_PATH=

###############################################################################
# WeChat Pay
###############################################################################

KQ_WECHAT_PAY_APPID=<fill-wechat-pay-appid>
KQ_WECHAT_PAY_MCHID=<fill-wechat-pay-mchid>
KQ_WECHAT_PAY_MERCHANT_SERIAL_NO=<fill-wechat-pay-merchant-serial-no>
KQ_WECHAT_PAY_PRIVATE_KEY=<fill-wechat-pay-private-key>
KQ_WECHAT_PAY_API_V3_KEY=<fill-wechat-pay-api-v3-key>
KQ_WECHAT_PAY_NOTIFY_URL=https://remotelink.kunqiongai.com/kq-api/api/payment/wechat/notify
KQ_WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com

# Optional path-based key variable. Leave empty unless using a server-local file.
KQ_WECHAT_PAY_PRIVATE_KEY_PATH=

###############################################################################
# Android artifact publish script
# Use these when running scripts/deploy/deploy-android.sh.
###############################################################################

ARTIFACT_DIR=artifacts
OUTPUT_DIR=/www/wwwroot/KQromoteLink/android
API_DOWNLOAD_DIR=/www/wwwroot/KQromoteLink/api/public/downloads
KQ_API_ENV_FILE=/www/wwwroot/KQromoteLink/.env

# Optional fallback version fields for Android publishing.
BUILD_NAME=
BUILD_NUMBER=

###############################################################################
# iOS Codemagic / TestFlight
# Set these in Codemagic group: appstore_credentials.
###############################################################################

FLUTTER_BUILD_NAME=1.4.6
FLUTTER_BUILD_NUMBER=4073

BUNDLE_ID=com.kunqiong.remotelink
EXTENSION_BUNDLE_ID=com.kunqiong.remotelink.broadcast

APP_STORE_CONNECT_PRIVATE_KEY=<fill-app-store-connect-p8-content>
APP_STORE_CONNECT_KEY_IDENTIFIER=<fill-key-id>
APP_STORE_CONNECT_ISSUER_ID=<fill-issuer-id>
APP_STORE_CONNECT_APPLE_ID=<fill-numeric-apple-id>

# Optional.
APP_STORE_CONNECT_ASC_PUBLIC_ID=
